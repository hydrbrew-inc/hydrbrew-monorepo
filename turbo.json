{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "SUPABASE_SECRET_KEY",
    "KLAVIYO_PRIVATE_KEY",
    "KLAVIYO_LIST_ID",
    "NEXT_PUBLIC_KLAVIYO_LIST_ID",
    "NEXT_PUBLIC_KLAVIYO_OURA_LIST_ID",
    "NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY",
    "KLAVIYO_API_REVISION",
    "VIRAL_LOOPS_API_TOKEN",
    "NEXT_PUBLIC_VIRAL_LOOPS_CAMPAIGN_ID",
    "CROSSMINT_API_KEY",
    "CROSSMINT_PROJECT_ID",
    "NEXT_PUBLIC_CROSSMINT_CLIENT_KEY",
    "LEVEL_UP_WEBHOOK_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types", "build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
